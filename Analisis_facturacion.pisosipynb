    {
      "cell_type": "markdown",
      "source": [
        "### Cambiar los estados_pago de 'pending' a 'pendiente'"
      ],
      "metadata": {
        "id": "OvlaibnvCnYH"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df['estado_pago']=df['estado_pago'].replace('pending', 'pendiente')\n",
        "df['estado_pago'].unique()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "c_YjqTLqCrhe",
        "outputId": "c65c97dd-4325-4fac-a50a-10ce15e1f331"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
