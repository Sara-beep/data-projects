      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "### Aplicar ONE HOT ENCODING para convertir los valores de estado_pago en columnas binarias"
      ],
      "metadata": {
        "id": "gxzUzKFqDCFX"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "pd.get_dummies(df['estado_pago'])\n",
        "df = pd.concat([df, pd.get_dummies(df['estado_pago'])], axis=1)\n",
        "df.info()\n",
